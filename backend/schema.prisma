generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id       String   @id @default(uuid())
  ticker   String
  type     String
  quantity Int
  price    Float
  date     DateTime
  sector   String
}
